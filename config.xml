<?xml version='1.0' encoding='utf-8'?>
<widget id="com.uzxx.coolapp" version="1.0.0" xmlns="http://www.w3.org/ns/widgets">
    <name>CoolApp</name>
    <description>Clean Mobile Sketchpad</description>
    <author>Veysi</author>
    <content src="index.html" />
    <access origin="*" />
    
    <preference name="SplashScreen" value="none" />
